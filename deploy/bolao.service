[Unit]
Description=Bolão da Copa WhatsApp Bot
After=network.target

[Service]
User=deploy
WorkingDirectory=/home/deploy/bolao_copa
ExecStart=/home/deploy/bolao_copa/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 app:app
Restart=always
RestartSec=5
EnvironmentFile=/home/deploy/bolao_copa/.env

[Install]
WantedBy=multi-user.target
